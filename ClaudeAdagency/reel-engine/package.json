{
  "name": "thecraftstudios-reel-engine",
  "version": "1.0.0",
  "description": "Production-ready AI reel generation pipeline for TheCraftStudios",
  "main": "src/api/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/api/server.js",
    "dev": "nodemon src/api/server.js",
    "worker:reel": "node src/workers/reelWorker.js",
    "worker:post": "node src/workers/postWorker.js",
    "workers": "concurrently \"npm run worker:reel\" \"npm run worker:post\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@aws-sdk/client-s3": "^3.614.0",
    "@aws-sdk/s3-request-presigner": "^3.614.0",
    "bullmq": "^5.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "node-fetch": "^3.3.2",
    "stripe": "^16.2.0",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4"
  }
}
