# ── Server ──────────────────────────────────────────
PORT=4000
NODE_ENV=production
FRONTEND_URL=https://thecraftstudios.in

# ── Redis (BullMQ) ───────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Anthropic / Claude ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Replicate (Video Generation) ─────────────────────
REPLICATE_API_TOKEN=r8_...

# ── ElevenLabs (Voice) ───────────────────────────────
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Suno (Music) ─────────────────────────────────────
SUNO_API_KEY=...
# Fallback royalty-free: pixabay / freemusicarchive
MUSIC_FALLBACK=pixabay

# ── AWS S3 (Storage) ─────────────────────────────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-south-1
S3_BUCKET=thecraftstudios-reels

# ── Meta / Instagram (Auto-posting) ──────────────────
META_APP_ID=...
META_APP_SECRET=...
META_INSTAGRAM_ACCOUNT_ID=...
# Long-lived user access token (60 days, refresh monthly)
META_ACCESS_TOKEN=...

# ── Stripe (Payments) ─────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs from your Stripe dashboard
STRIPE_PRICE_100_CREDITS=price_...
STRIPE_PRICE_500_CREDITS=price_...
STRIPE_PRICE_1000_CREDITS=price_...

# ── Auth (JWT) ────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRY=7d

# ── FFmpeg ────────────────────────────────────────────
# Path to ffmpeg binary (leave empty to use system PATH)
FFMPEG_PATH=
FFPROBE_PATH=

# ── Credits ────────────────────────────────────────────
# 1 second of reel = CREDITS_PER_SECOND credits
CREDITS_PER_SECOND=2
FREE_REGENERATIONS=3
NEW_USER_BONUS_CREDITS=30
