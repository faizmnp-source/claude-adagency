# ── AI / Script ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Voice (ElevenLabs) ────────────────────────────────────
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Rachel — change per brand

# ── Video (Runway ML) ─────────────────────────────────────
RUNWAY_API_KEY=...

# ── Instagram Graph API ───────────────────────────────────
