# ── Supabase ──────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-key

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── AI / Script (Claude Sonnet) ───────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Voice (ElevenLabs) ────────────────────────────────
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Video — Kling 2.0 (primary, best quality) ─────────
# Get key: klingai.com → API → Create key
KLING_API_KEY=...

# ── Video — Runway Gen-4 Turbo (fallback) ─────────────
# Get key: runwayml.com → API
RUNWAY_API_KEY=...

# ── Instagram Graph API ───────────────────────────────
# Setup guide: developers.facebook.com → New App → Instagram Graph API
# 1. Create app, add Instagram product
# 2. Connect Instagram Business Account
# 3. Generate long-lived token (valid 60 days)
IG_ACCOUNT_ID=your-ig-business-account-id
IG_ACCESS_TOKEN=your-long-lived-page-access-token
IG_APP_ID=...
IG_APP_SECRET=...

# ── WhatsApp Cloud API (optional) ─────────────────────
WHATSAPP_TOKEN=...
WHATSAPP_PHONE_NUMBER_ID=...
WHATSAPP_VERIFY_TOKEN=your-random-verify-token
CLIENT_WHATSAPP_NUMBER=+1234567890

# ── Frontend ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
